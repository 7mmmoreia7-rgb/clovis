<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html, body { width:100%; height:100%; overflow:hidden; background:#000; }
#wrap { position:relative; width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:#000; }
#stage { position:relative; overflow:hidden; }
#vid { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; z-index:1; }
#play { position:absolute; left:50%; top:50%; transform:translate(-50%,-50%); width:10%; cursor:pointer; z-index:10; transition:transform .2s, opacity .5s; }
#play.gone { opacity:0; pointer-events:none; }
#btn-email { position:absolute; left:16.58%; top:31.00%; width:6.41%; height:11.32%; object-fit:contain; cursor:pointer; z-index:10; opacity:0; pointer-events:none; transition:opacity .3s; }
#btn-email.show { opacity:0; pointer-events:all; }
#btn-email.show:hover { opacity:1; filter:drop-shadow(0 0 8px rgba(255,255,255,0.8)); }
#foto-area { position:absolute; left:9.50%; top:19.00%; width:19%; height:33%; z-index:9; cursor:pointer; opacity:0; pointer-events:none; }
#foto-area.show { pointer-events:all; opacity:0; }
#foto-area:hover ~ #btn-email, #btn-email:hover { opacity:1 !important; }
#btn-idx { position:absolute; bottom:10%; right:5%; width:8%; cursor:pointer; z-index:10; opacity:0; pointer-events:none; transition:opacity .8s; }
#btn-idx.show { opacity:1; pointer-events:all; }
</style>
</head>
<body>
<div id="wrap"><div id="stage">

  <video id="vid" src="https://res.cloudinary.com/dxdemxfpe/video/upload/v1773223405/betriz_b4xebp.mp4" preload="auto" playsinline></video>

  <img id="play" src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958888/26_ujjdad.png" />

  <div id="foto-area"></div>

  <img id="btn-email" src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1772411225/ChatGPT_Image_Jan_25__2026__01_04_01_AM-removebg-preview_juxpsr.png" alt="email" />

  <img id="btn-idx" src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773223424/botao_2_eu0w6r.png" />

</div></div>
<script>
function resize(){
  var wrap=document.getElementById('wrap'), stage=document.getElementById('stage');
  var ww=wrap.clientWidth, wh=wrap.clientHeight, ratio=16/9, w, h;
  if(ww/wh>ratio){h=wh;w=h*ratio;}else{w=ww;h=w/ratio;}
  stage.style.width=w+'px'; stage.style.height=h+'px';
}
resize(); window.addEventListener('resize',resize);

var vid=document.getElementById('vid');

document.getElementById('play').onclick=function(){
  this.classList.add('gone');
  vid.play().catch(function(){vid.muted=true;vid.play();});
};

vid.addEventListener('ended',function(){
  document.getElementById('btn-email').classList.add('show');
  document.getElementById('foto-area').classList.add('show');
  document.getElementById('btn-idx').classList.add('show');
});

document.getElementById('btn-email').onclick=function(){
  window.open('mailto:beatrizfreimor4@gmail.com');
};

document.getElementById('btn-idx').onclick=function(){
  window.top.location.href='/version-test/indice?skip=1';
};
</script>
</body>
</html>
