      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946655/21_ceocw1.png" data-e="e21" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946655/22_hmr1hw.png" data-e="e22" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946656/23_kml500.png" data-e="e23" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946659/24_g3s3tv.png" data-e="e24" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946660/25_xzzpnb.png" data-e="e25" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946661/26_x0fevy.png" data-e="e26" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946664/27_mhftar.png" data-e="e27" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946665/28_bjttw8.png" data-e="e28" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946669/31_dfdbpj.png" data-e="e29" />
    </div>
    <div id="chat-input" contenteditable="true" data-ph="escreve aqui…" role="textbox"></div>
    <button id="btn-clovis"></button>
    <button id="btn-enviar"></button>
    <button id="btn-export"></button>
    <button id="btn-import"></button>
    <input id="file-import" type="file" accept="image/*,video/*" multiple />
    <img id="btn-idx" src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773223424/botao_2_eu0w6r.png" alt="índice" />
    <div id="fs-overlay">
      <img id="fs-img" src="" alt="" style="display:none;" />
      <video id="fs-vid" controls playsinline style="display:none;"></video>
      <div style="display:flex;gap:10px;margin-top:10px;">
        <button id="fs-close">✕ Fechar</button>
        <button id="fs-save">💾 Guardar</button>
      </div>
    </div>
  </div>

</div></div>
<script>
function resize(){
  var ww=window.innerWidth, wh=window.innerHeight;
  var r=16/9, sw, sh;
  if(ww/wh>r){sh=wh;sw=sh*r;}else{sw=ww;sh=sw/r;}
  var s=document.getElementById('stage');
  s.style.width=sw+'px';
  s.style.height=sh+'px';
  s.style.fontSize=(sw/1920*26)+'px';
}
resize();
window.addEventListener('resize',resize);
document.addEventListener('touchmove',function(e){e.preventDefault();},{passive:false});

var SURL='https://itqzgxotbzsuwevjpnoi.supabase.co';
var SKEY='eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml0cXpneG90YnpzdXdldmpwbm9pIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE3MDU4NTgsImV4cCI6MjA4NzI4MTg1OH0.nS4RuwfULc9uHGh_u93vLZ7uRsLnKl7NULrb2Yesw9k';
var HDR={'apikey':SKEY,'Authorization':'Bearer '+SKEY,'Content-Type':'application/json'};
function sGet(q){return fetch(SURL+'/rest/v1/mensagens?'+q,{headers:HDR}).then(function(r){return r.json();});}
function sInsert(d){return fetch(SURL+'/rest/v1/mensagens',{method:'POST',headers:Object.assign({'Prefer':'return=representation'},HDR),body:JSON.stringify(d)}).then(function(r){return r.json();}).then(function(rows){if(rows&&rows.length&&rows[0].id){idsEnviados[rows[0].id]=true;}});}
var nome='',ultimoId=0,idsEnviados={};

var EU={
  e1:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946627/1_pz5cc5.png',
  e2:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946627/2_dsh9ek.png',
  e3:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946628/3_ac3mhj.png',
  e4:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946628/4_xwaihb.png',
  e5:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946632/5_s1ahp6.png',
  e6:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946633/6_ugbsc8.png',
  e7:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946635/7_kehixy.png',
  e8:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946635/8_le9rad.png',
  e9:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946636/9_l92zm4.png',
  e10:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946639/10_oycjvw.png',
  e11:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946640/11_eylkgz.png',
  e12:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946642/12_vrifn2.png',
  e13:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946643/13_a0927x.png',
  e14:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946644/14_zslnxa.png',
  e15:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946646/15_e7ldbf.png',
  e16:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946647/16_puprtb.png',
  e17:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946648/17_g0knc8.png',
  e18:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946650/18_szhsqj.png',
  e19:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946651/19_pxdx6i.png',
  e20:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946652/20_wcsvn8.png',
  e21:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946655/21_ceocw1.png',
  e22:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946655/22_hmr1hw.png',
  e23:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946656/23_kml500.png',
  e24:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946659/24_g3s3tv.png',
  e25:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946660/25_xzzpnb.png',
  e26:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946661/26_x0fevy.png',
