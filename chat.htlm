<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>Chat</title>
<link rel="icon" href="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773223424/botao_2_eu0w6r.png" />
<link rel="apple-touch-icon" href="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773223424/botao_2_eu0w6r.png" />
<link href="https://fonts.googleapis.com/css2?family=Caveat:wght@700&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
::-webkit-scrollbar { display:none!important; width:0!important; height:0!important; }
* { scrollbar-width:none!important; -ms-overflow-style:none!important; }
html { width:100vw; height:100vh; overflow:hidden; background:#c8b99a; }
body { width:100vw; height:100vh; overflow:hidden; background:#c8b99a; }
#wrap { position:fixed; top:0; left:0; width:100vw; height:100vh; display:flex; align-items:center; justify-content:center; background:#c8b99a; overflow:hidden; }
#stage { position:relative; overflow:hidden; background:#c8b99a; flex-shrink:0; }
.pagina { position:absolute; inset:0; }
#pag-login { z-index:5; }
#pag-chat  { z-index:4; display:none; }
#bg-login, #bg-chat { position:absolute; inset:0; width:100%; height:100%; object-fit:cover; display:block; }
#login-input { position:absolute; left:31%; top:59%; width:37%; height:6%; z-index:20; border:none; outline:none; background:transparent; font-size:1.2em; font-family:'Caveat',cursive; text-align:center; color:#111; }
#btn-entra { position:absolute; left:38%; top:69%; width:24%; height:12%; z-index:20; background:transparent; border:none; cursor:pointer; }
#msgs-box { position:absolute; left:14.48%; top:20.46%; width:71%; height:46.20%; z-index:10; overflow:hidden; padding:1.5% 3% 0.5% 3%; display:flex; flex-direction:column; gap:2px; overflow-y:scroll; }
.msg { display:block; flex-shrink:0; line-height:1.6; overflow-wrap:break-word; word-break:break-word; animation:fadeIn .2s ease; }
.msg .autor { font-family:'Caveat',cursive; font-size:1.05em; font-weight:700; color:#c00; margin-right:3px; }
.msg .texto { font-family:Georgia,serif; font-size:0.85em; color:#111; overflow-wrap:break-word; word-break:break-word; }
.msg .texto img.emoji { min-height:3.5em; min-width:3.5em; max-height:5em; max-width:5em; object-fit:contain; vertical-align:middle; display:inline-block; }
.msg .texto img.media-img { max-height:3.5em; border-radius:4px; cursor:pointer; display:inline-block; vertical-align:middle; }
.msg .texto img.media-img.sel { outline:3px solid #c00; }
.msg .texto video { max-height:3.5em; border-radius:4px; cursor:pointer; display:inline-block; vertical-align:middle; }
.msg .texto video.sel { outline:3px solid #00c; }
@keyframes fadeIn { from{opacity:0;transform:translateY(2px);}to{opacity:1;transform:none;} }
#chat-input { position:absolute; left:20%; top:71%; width:59%; height:9.35%; z-index:10; border:none; outline:none; background:transparent; font-family:Georgia,serif; font-size:0.9em; color:#111; padding:0.7em 0.8em 0.4em 0.8em; overflow:hidden; overflow-wrap:break-word; word-break:break-word; white-space:pre-wrap; line-height:1.4; display:none; cursor:text; }
#chat-input:empty::before { content:attr(data-ph); color:#bbb; pointer-events:none; }
#chat-input img.emoji { min-height:3.5em; min-width:3.5em; max-height:5em; max-width:5em; object-fit:contain; vertical-align:middle; display:inline-block; }
#btn-enviar { position:absolute; left:81.5%; top:63.5%; width:9.5%; height:16%; z-index:15; background:transparent; border:none; cursor:pointer; }
#btn-clovis { position:absolute; left:14.48%; top:63.5%; width:6%; height:16%; z-index:15; background:transparent; border:none; cursor:pointer; }
#btn-export { position:absolute; left:64.7%; top:0%; width:11%; height:14%; z-index:15; background:transparent; border:none; cursor:pointer; }
#btn-import { position:absolute; left:78.9%; top:0%; width:11%; height:14%; z-index:15; background:transparent; border:none; cursor:pointer; }
#file-import { display:none; }
#btn-idx { position:absolute; right:3%; bottom:10%; width:8%; height:auto; object-fit:contain; cursor:pointer; z-index:10; opacity:0; pointer-events:none; transition:opacity .5s; }
#btn-idx.show { opacity:1; pointer-events:all; }
#emoji-panel { position:absolute; left:14.48%; top:26%; width:46%; height:36%; z-index:30; background:rgba(255,255,255,0.97); border-radius:10px; border:2px solid #ddd; display:none; flex-wrap:wrap; align-items:flex-start; justify-content:flex-start; gap:8px; padding:10px; box-shadow:0 4px 20px rgba(0,0,0,0.2); overflow-y:auto; }
#emoji-panel.open { display:flex; }
#emoji-panel img { width:80px; height:80px; object-fit:contain; cursor:pointer; transition:transform .15s; flex-shrink:0; }
#emoji-panel img:hover { transform:scale(1.15); }
#fs-overlay { position:fixed; inset:0; z-index:500; background:url(https://res.cloudinary.com/dxdemxfpe/image/upload/v1771887590/isto_f3c09e.png) center/cover; display:none; align-items:center; justify-content:center; flex-direction:column; gap:12px; }
#fs-overlay.open { display:flex; }
#fs-overlay img#fs-img { max-width:90%; max-height:80%; border-radius:8px; object-fit:contain; }
#fs-overlay video#fs-vid { max-width:90%; max-height:80%; border-radius:8px; }
#fs-close { background:rgba(0,0,0,.55); border:1px solid rgba(255,255,255,.4); color:#fff; border-radius:8px; padding:8px 28px; font-size:1em; font-weight:700; cursor:pointer; z-index:501; transition:background .2s; }
#fs-close:hover { background:rgba(0,0,0,.8); }
#fs-save { background:rgba(0,0,0,.55); border:1px solid rgba(255,255,255,0.4); color:#fff; border-radius:8px; padding:8px 24px; font-size:1em; font-weight:700; cursor:pointer; transition:background .2s; }
#fs-save:hover { background:rgba(0,0,0,.8); }
</style>
</head>
<body>
<div id="wrap"><div id="stage">

  <div id="pag-login" class="pagina">
    <img id="bg-login" src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1771845348/chat_2_xxurxp.png" alt="" />
    <input id="login-input" type="text" maxlength="20" autocomplete="off" spellcheck="false" />
    <button id="btn-entra"></button>
  </div>

  <div id="pag-chat" class="pagina">
    <img id="bg-chat" src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773599543/isto_n%C3%A3o_%C3%A9_para_todos_3_ntshdn.png" alt="" />
    <div id="msgs-box"></div>
    <div id="emoji-panel">
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946627/1_pz5cc5.png" data-e="e1" />
      <img src="https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946627/2_dsh9ek.png" data-e="e2" />
