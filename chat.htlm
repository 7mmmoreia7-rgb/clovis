  e28:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946665/28_bjttw8.png',
  e29:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946669/31_dfdbpj.png',
  furioso:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946627/1_pz5cc5.png',
  triste:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946627/2_dsh9ek.png',
  oculos:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946628/3_ac3mhj.png',
  amor:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946628/4_xwaihb.png',
  beijo:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946632/5_s1ahp6.png',
  rir:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946633/6_ugbsc8.png',
  chorar:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946635/7_kehixy.png',
  recriar:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1773946635/8_le9rad.png',
  e28old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958889/28_slhtba.png',
  e27old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958888/27_d8qg3d.png',
  e26old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958888/26_ujjdad.png',
  e25old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958885/25_o0j4dm.png',
  e24old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958884/24_zcummy.png',
  e23old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958884/23_jcdqhp.png',
  e21old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958884/21_pfzygy.png',
  e22old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958884/22_nzbwou.png',
  e19old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958858/19_z7irbi.jpg',
  e20old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958859/20_rrlu1k.jpg',
  e16old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958858/16_k43ivp.png',
  e12old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958858/12_wl0i5e.png',
  e17old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958858/17_c8obvb.png',
  e18old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958858/18_fkh5ge.png',
  ewipe:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958857/Image_20260207_010943_wipe_bg_illq4e.png',
  e15old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958858/15_hdl0mw.png',
  e10old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958857/10_wau9uz.png',
  ev1:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958857/v_1__wipe_bg_w6jtl9.png',
  eulok:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958857/%C3%B9lok_po_wipe_bg_vl99e8.png',
  e14old:'https://res.cloudinary.com/dxdemxfpe/image/upload/v1772958857/14_tjhjdh.png'
};
var U2C={};Object.keys(EU).forEach(function(k){U2C[EU[k]]=k;});

function entrar(){
  var v=document.getElementById('login-input').value.trim();if(!v)return;
  nome=v;
  document.getElementById('pag-login').style.display='none';
  document.getElementById('pag-chat').style.display='block';
  document.getElementById('btn-idx').classList.add('show');
  document.getElementById('chat-input').style.display='block';
  iniciarChat();
}
document.getElementById('btn-entra').onclick=entrar;
document.getElementById('login-input').onkeydown=function(e){if(e.key==='Enter')entrar();};

function iniciarChat(){
  sGet('select=*&order=created_at.asc&limit=80').then(function(data){
    if(!Array.isArray(data))return;
    data.forEach(addMsg);
    if(data.length)ultimoId=data[data.length-1].id;
    scrollDown();
  });
  setInterval(function(){
    if(!ultimoId)return;
    sGet('select=*&order=created_at.asc&id=gt.'+ultimoId).then(function(data){
      if(!Array.isArray(data)||!data.length)return;
      data.forEach(function(m){if(!idsEnviados[m.id])addMsg(m);delete idsEnviados[m.id];});
      ultimoId=data[data.length-1].id;scrollDown();
    });
  },2000);
}

function toHtml(t){
  if(!t)return'';
  if(t.startsWith('[img:')){var u=t.slice(5,-1);return'<img class="media-img" src="'+u+'" data-f="'+u+'">';}
  if(t.startsWith('[vid:')){var u=t.slice(5,-1);return'<video src="'+u+'" data-vsrc="'+u+'" playsinline></video>';}
  var p=t.split(/(:[a-z0-9]+:)/g),h='';
  p.forEach(function(s){var m=s.match(/^:([a-z0-9]+):$/);if(m&&EU[m[1]])h+='<img class="emoji" src="'+EU[m[1]]+'">';else h+=esc(s);});
  return h;
}
function addMsg(m){
  var b=document.getElementById('msgs-box'),d=document.createElement('div');d.className='msg';
  d.innerHTML='<span class="autor">'+esc(m.nome)+':</span> <span class="texto">'+toHtml(m.texto)+'</span>';
  b.appendChild(d);
}
function scrollDown(){var b=document.getElementById('msgs-box');b.scrollTop=b.scrollHeight;}
function esc(s){return(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}

function lerInput(){
  var i=document.getElementById('chat-input'),t='';
  i.childNodes.forEach(function(n){
    if(n.nodeType===Node.TEXT_NODE)t+=n.textContent;
    else if(n.nodeName==='IMG'){var c=U2C[n.getAttribute('src')];if(c)t+=':'+c+':';}
    else if(n.nodeName==='BR')t+=' ';
    else t+=n.textContent;
  });
  return t.trim();
}
function enviar(){
  var t=lerInput();if(!t||!nome)return;
  document.getElementById('chat-input').innerHTML='';
  addMsg({nome:nome,texto:t});scrollDown();sInsert({nome:nome,texto:t});
}
document.getElementById('btn-enviar').onclick=enviar;
document.getElementById('chat-input').addEventListener('keydown',function(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();enviar();}});

document.getElementById('btn-clovis').onclick=function(e){e.stopPropagation();document.getElementById('emoji-panel').classList.toggle('open');};
document.querySelectorAll('#emoji-panel img').forEach(function(img){
  img.onclick=function(e){
    e.stopPropagation();
    var inp=document.getElementById('chat-input');inp.focus();
    var sel=window.getSelection(),range;
    if(sel&&sel.rangeCount>0){range=sel.getRangeAt(0);if(!inp.contains(range.commonAncestorContainer)){range=document.createRange();range.selectNodeContents(inp);range.collapse(false);}}
    else{range=document.createRange();range.selectNodeContents(inp);range.collapse(false);}
    var ei=document.createElement('img');
    ei.src=EU[this.dataset.e];ei.className='emoji';
    ei.style.minHeight='3.5em';ei.style.minWidth='3.5em';ei.style.maxHeight='5em';ei.style.maxWidth='5em';ei.style.objectFit='contain';ei.style.verticalAlign='middle';ei.style.display='inline-block';
    range.deleteContents();range.insertNode(ei);range.setStartAfter(ei);range.collapse(true);
    sel.removeAllRanges();sel.addRange(range);
    document.getElementById('emoji-panel').classList.remove('open');inp.focus();
  };
});
document.addEventListener('click',function(e){
  if(!document.getElementById('emoji-panel').contains(e.target)&&e.target!==document.getElementById('btn-clovis'))
    document.getElementById('emoji-panel').classList.remove('open');
});

document.getElementById('btn-import').onclick=function(){document.getElementById('file-import').click();};
document.getElementById('file-import').onchange=function(){
  if(!this.files.length||!nome)return;
  Array.from(this.files).forEach(function(f){
    var path='chat_'+Date.now()+'_'+Math.random().toString(36).slice(2)+'.'+f.name.split('.').pop();
    var tipo=f.type.startsWith('video')?'vid':'img';
    fetch(SURL+'/storage/v1/object/chat/'+path,{
      method:'POST',
      headers:{'apikey':SKEY,'Authorization':'Bearer '+SKEY,'Content-Type':f.type,'x-upsert':'true'},
      body:f
    }).then(function(){
      var url=SURL+'/storage/v1/object/public/chat/'+path;
      var texto='['+tipo+':'+url+']';
      addMsg({nome:nome,texto:texto});scrollDown();sInsert({nome:nome,texto:texto});
    }).catch(function(){alert('Erro ao enviar ficheiro');});
  });this.value='';
};

var fsAtualSrc=null,fsAtualTipo=null;
document.getElementById('msgs-box').addEventListener('click',function(e){
  var t=e.target;
  if(t.tagName==='VIDEO'){abrirFs('video',t.getAttribute('data-vsrc')||t.src);return;}
  if(t.tagName==='IMG'&&t.classList.contains('media-img')){abrirFs('img',t.getAttribute('data-f')||t.src);return;}
});

document.getElementById('btn-export').onclick=function(){if(!fsAtualSrc)return;guardarFs();};

function abrirFs(tipo,src){
  if(!src)return;
  fsAtualSrc=src;fsAtualTipo=tipo;
  var img=document.getElementById('fs-img'),vid=document.getElementById('fs-vid');
  if(tipo==='img'){img.src=src;img.style.display='block';vid.pause();vid.src='';vid.style.display='none';}
  else{vid.src=src;vid.style.display='block';vid.play().catch(function(){});img.src='';img.style.display='none';}
  document.getElementById('fs-overlay').classList.add('open');
}
function fecharFs(){
  var vid=document.getElementById('fs-vid');vid.pause();vid.src='';vid.style.display='none';
  var img=document.getElementById('fs-img');img.src='';img.style.display='none';
  document.getElementById('fs-overlay').classList.remove('open');
  fsAtualSrc=null;fsAtualTipo=null;
}
function guardarFs(){
  if(!fsAtualSrc)return;
  fetch(fsAtualSrc)
  .then(function(r){return r.blob();})
  .then(function(blob){
    var url=URL.createObjectURL(blob);
    var a=document.createElement('a');
    a.href=url;a.download=fsAtualTipo==='video'?'video.mp4':'imagem.jpg';
    document.body.appendChild(a);a.click();
    document.body.removeChild(a);URL.revokeObjectURL(url);
  }).catch(function(){
    var a=document.createElement('a');a.href=fsAtualSrc;a.download=fsAtualTipo==='video'?'video.mp4':'imagem.jpg';a.target='_blank';
    document.body.appendChild(a);a.click();document.body.removeChild(a);
  });
}

document.getElementById('fs-close').addEventListener('click',function(e){e.stopPropagation();fecharFs();});
document.getElementById('fs-save').addEventListener('click',function(e){e.stopPropagation();guardarFs();});
document.getElementById('fs-overlay').addEventListener('click',function(e){if(e.target===this)fecharFs();});
document.addEventListener('keydown',function(e){if(e.key==='Escape')fecharFs();});

document.getElementById('btn-idx').onclick=function(){window.location.href='/indice';};
</script>
</body>
</html>
